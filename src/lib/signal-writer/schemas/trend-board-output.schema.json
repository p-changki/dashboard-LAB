{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "boardSummary",
    "hook",
    "shortPost",
    "threadPosts",
    "firstComment",
    "followUpReplies",
    "hashtags",
    "whyNow",
    "postingTips"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "boardSummary": { "type": "string", "minLength": 1 },
    "hook": { "type": "string", "minLength": 1 },
    "shortPost": { "type": "string", "minLength": 1 },
    "threadPosts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "firstComment": { "type": "string" },
    "followUpReplies": { "type": "array", "items": { "type": "string" } },
    "hashtags": { "type": "array", "items": { "type": "string" } },
    "whyNow": { "type": "string", "minLength": 1 },
    "postingTips": { "type": "array", "items": { "type": "string" } }
  }
}
