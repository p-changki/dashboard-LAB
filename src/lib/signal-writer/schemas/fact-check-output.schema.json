{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "confidence", "summary", "findings", "rewriteBrief"],
  "properties": {
    "verdict": { "type": "string", "enum": ["pass", "mixed", "fail"] },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "reason", "suggestedFix"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["supported", "uncertain", "incorrect"] },
          "reason": { "type": "string", "minLength": 1 },
          "suggestedFix": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rewriteBrief": { "type": "string", "minLength": 1 }
  }
}
